<Window x:Class="MuseumClient.Views.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360"
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White"
            CornerRadius="15"
            Padding="25"
            BorderBrush="#B0B0B0"
            BorderThickness="2"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">

        <Border.Effect>
            <DropShadowEffect BlurRadius="25"
                              ShadowDepth="4"
                              Opacity="0.0"/>
        </Border.Effect>


        <StackPanel>

            <TextBlock Text="Подтверждение удаления"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#334155"
                       HorizontalAlignment="Center"/>


            <TextBlock Text="{Binding Message}"
                       Margin="0,20,0,25"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Foreground="#555"
                       FontSize="14"/>


            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Удалить"
                        Width="130"
                        Height="35"
                        Margin="4"
                        Background="#EF4444"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Yes_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>


                <Button Content="Отмена"
                        Width="130"
                        Height="35"
                        Margin="4"
                        Background="#E5E7EB"
                        Foreground="#374151"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="No_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

            </StackPanel>

        </StackPanel>

    </Border>

</Window>