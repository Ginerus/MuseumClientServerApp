<UserControl x:Class="MuseumClient.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:MuseumClient.Helpers">

    <Grid Background="#F5F6FA">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Border Grid.Column="0"
                Background="#4A90E2">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Image Source="pack://application:,,,/Resources/logo.png"
                       Width="160"
                       Height="160"
                       Margin="0,0,0,20"/>

                <TextBlock Text="Добро пожаловать"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Музей &quot;Память времён&quot;"
                           Foreground="White"
                           FontSize="14"
                           Opacity="0.9"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>

                <TextBlock Text="Система управления экспонатами"
                           Foreground="White"
                           FontSize="12"
                           Opacity="0.7"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>

            </StackPanel>
        </Border>

        <!-- RIGHT -->
        <Border Grid.Column="1"
                Background="White"
                Padding="40">

            <StackPanel VerticalAlignment="Center"
                        Width="320">

                <!-- USER TYPE заменён -->
                <ComboBox ItemsSource="{Binding UserTypes}"
                          SelectedItem="{Binding SelectedUserType, Mode=TwoWay}"
                          DisplayMemberPath="Display"
                          Margin="0,0,0,10"
                          Height="35"/>

                <Grid>

                    <PasswordBox
                        local:PasswordBoxHelper.BoundPassword="{Binding UserPassword, Mode=TwoWay}"
                        Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=False}" />

                    <TextBox
                        Text="{Binding UserPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Button
                        Command="{Binding TogglePasswordVisibilityCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        Panel.ZIndex="10">

                        <iconPacks:PackIconMaterial
                            Width="18"
                            Height="18"
                            Kind="{Binding IsPasswordVisible, Converter={StaticResource EyeGlyphConverter}}"/>
                    </Button>

                </Grid>

                <Button Content="Войти"
                        Command="{Binding RegisterCommand}"
                        Margin="0,15,0,0"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           Margin="0,10,0,0"/>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>