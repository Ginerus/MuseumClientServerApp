<UserControl x:Class="MuseumClient.Views.Details.DocumentViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MuseumClient.Views.Details"
             mc:Ignorable="d"
             xmlns:conv="clr-namespace:MuseumClient.Converters">
    
    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="White">

        <ScrollViewer>

            <StackPanel Margin="20">

                <TextBlock Text="{Binding Title}"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

                <!-- TXT / MD -->
                <TextBlock Text="{Binding Text}"
                       TextWrapping="Wrap"
                       FontFamily="Consolas"
                       Visibility="{Binding Text, Converter={StaticResource NullToVisibilityConverter}}"/>

                <!-- fallback -->
                <TextBlock Text="PDF / DOCX откроется отдельно"
                       Foreground="Gray"
                       Margin="0,10"/>

                <Button Content="Скачать"
                    Command="{Binding DownloadCommand}"
                    Width="120"
                    Margin="0,15"/>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</UserControl>
