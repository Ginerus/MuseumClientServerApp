<UserControl x:Class="MuseumClient.Views.Details.DocumentViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:beh="clr-namespace:MuseumClient.Behaviors"
             xmlns:conv="clr-namespace:MuseumClient.Converters">

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER (фиксированный) -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="16"
                Padding="15"
                Margin="20,20,20,10"
                BorderBrush="#E5E7EB"
                BorderThickness="2">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock Text="{Binding Title}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1F2937"/>

                    <TextBlock Text="Статья музея"
                           FontSize="13"
                           Foreground="#6B7280"/>

                </StackPanel>

                <Button Grid.Column="1"
                        Content="Скачать"
                        Command="{Binding DownloadCommand}"
                        Width="120"
                        Height="36"
                        Background="#4A90E2"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        FontFamily="Segoe UI"
                        Cursor="Hand"/>

            </Grid>

        </Border>

        <!-- CONTENT AREA -->
        <Border Grid.Row="1"
                Margin="20,0,20,20"
                CornerRadius="16"
                Background="#F3F4F6"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                ClipToBounds="True">

            <!-- ЕДИНЫЙ КОНТЕЙНЕР -->
            <Grid>

                <!-- TXT -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsText, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Border Background="White"
                            Padding="15"
                            Margin="10"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="12">

                        <TextBox Text="{Binding Text}"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"/>
                    </Border>

                </ScrollViewer>

                <!-- PDF -->
                <Border Visibility="{Binding IsHtml, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="White"
                        Padding="10"
                        Margin="10"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="12">

                    <wv2:WebView2 x:Name="PdfView">

                        <i:Interaction.Behaviors>
                            <beh:WebView2PdfBehavior/>
                            <beh:WebView2HtmlBehavior HtmlPath="{Binding HtmlPath}" />
                        </i:Interaction.Behaviors>

                    </wv2:WebView2>

                </Border>

            </Grid>

        </Border>

        <!-- OVERLAY ЗАГРУЗКИ -->
        <Grid Grid.RowSpan="2"
      Panel.ZIndex="999"
      Background="#66000000"
      Visibility="{Binding IsLoading,
                           Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Width="260"
            Height="140"
            Background="#1F2937"
            CornerRadius="16"
            Opacity="0.95"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                    <ProgressBar Width="180"
                         Height="8"
                         IsIndeterminate="True"
                         Margin="0,0,0,15"/>

                    <TextBlock Text="{Binding Status}"
                       Foreground="White"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="10,0,10,0"/>

                </StackPanel>

            </Border>

        </Grid>
    </Grid>
</UserControl>