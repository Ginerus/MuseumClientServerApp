<UserControl x:Class="MuseumClient.Views.Details.AddDepartmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:MuseumClient.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </UserControl.Resources>

    <Grid Background="White">

        <Grid.ColumnDefinitions>

            <!-- фото -->
            <ColumnDefinition Width="0.9*"
                              MinWidth="320"/>

            <ColumnDefinition Width="20"/>

            <!-- информация -->
            <ColumnDefinition Width="1.6*"/>

        </Grid.ColumnDefinitions>

        <!-- ================= -->
        <!-- IMAGE AREA -->
        <!-- ================= -->

        <Grid Grid.Column="0"
              Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="16"
                    BorderBrush="#E5E7EB"
                    BorderThickness="2"
                    MinHeight="300">

                <Grid>

                    <Image Source="{Binding Image}"
                           Visibility="{Binding Image, Converter={StaticResource NullToVisibility}}"
                           Stretch="Uniform"
                           Margin="15"/>

                    <TextBlock Text="Изображение не выбрано"
                               Foreground="#9CA3AF"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding Image,
                                            Converter={StaticResource NullToVisibility},
                                            ConverterParameter=Inverse}"/>
                </Grid>

            </Border>

            <Button Grid.Row="1"
                    Height="42"
                    Margin="0,15,0,0"
                    Cursor="Hand"
                    Background="White"
                    BorderBrush="#4A90E2"
                    BorderThickness="2"
                    Padding="15,0"
                    Command="{Binding SelectImageCommand}">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>

                <TextBlock Text="Выбрать изображение"
                           Foreground="#2563EB"
                           FontWeight="SemiBold"
                           FontSize="14"/>

            </Button>

            <TextBlock Grid.Row="2"
                       Text="{Binding SelectedImagePath}"
                       MaxWidth="300"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="#6B7280"
                       FontSize="12"/>
        </Grid>

        <!-- ================= -->
        <!-- RIGHT CONTENT -->
        <!-- ================= -->

        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="20">

                <!-- HEADER -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="2"
                        Margin="0,0,0,15">

                    <DockPanel LastChildFill="True">

                        <Button DockPanel.Dock="Right"
                                Content="Добавить"
                                Width="130"
                                Height="38"
                                Margin="15,0,0,0"
                                Background="#4A90E2"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Command="{Binding SaveCommand}">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                        <StackPanel>
                            <TextBlock Text="Новый отдел"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#1F2937"/>
                            <TextBlock Text="Заполните информацию"
                                       Margin="0,5,0,0"
                                       Foreground="#6B7280"/>
                        </StackPanel>

                    </DockPanel>

                </Border>

                <!-- НАЗВАНИЕ -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="2"
                        Margin="0,0,0,15">

                    <StackPanel>
                        <TextBlock Text="Название"
                                   FontWeight="SemiBold"
                                   FontSize="16"/>
                        <TextBox Height="36"
                                 Margin="0,8,0,0"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                </Border>

                <!-- ОПИСАНИЕ -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="2">

                    <StackPanel>
                        <TextBlock Text="Описание"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Separator Margin="0,10"/>

                        <TextBox MinHeight="180"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>
