<UserControl x:Class="MuseumClient.Views.Details.DepartmentCatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <UserControl.Resources>

        <!-- Кнопка карточки без рамки WPF -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Кнопка-вкладка секции -->
        <Style x:Key="SectionTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="{Binding DepartmentName}"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   Margin="20,20,20,10"/>

        <!-- Переключатель секций -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="16,0,16,10">
            <Button Content="📚 Всё"
                Command="{Binding SelectSectionCommand}"
                CommandParameter="All">
                <Button.Style>
                    <Style BasedOn="{StaticResource SectionTabButtonStyle}" TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="All">
                                <Setter Property="Background" Value="#4A70FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="🏺 Экспонаты"
                    Command="{Binding SelectSectionCommand}"
                    CommandParameter="Exhibits">
                <Button.Style>
                    <Style BasedOn="{StaticResource SectionTabButtonStyle}" TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="Exhibits">
                                <Setter Property="Background" Value="#4A70FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="📰 Статьи"
                    Command="{Binding SelectSectionCommand}"
                    CommandParameter="Articles">
                <Button.Style>
                    <Style BasedOn="{StaticResource SectionTabButtonStyle}" TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="Articles">
                                <Setter Property="Background" Value="#4A70FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="🖼 Изображения"
                    Command="{Binding SelectSectionCommand}"
                    CommandParameter="Images">
                <Button.Style>
                    <Style BasedOn="{StaticResource SectionTabButtonStyle}" TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="Images">
                                <Setter Property="Background" Value="#4A70FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="🎥 Видео"
                    Command="{Binding SelectSectionCommand}"
                    CommandParameter="Videos">
                <Button.Style>
                    <Style BasedOn="{StaticResource SectionTabButtonStyle}" TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSection}" Value="Videos">
                                <Setter Property="Background" Value="#4A70FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>

        <!-- Контент секций -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <!-- ЭКСПОНАТЫ -->
                <ItemsControl ItemsSource="{Binding Exhibits}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.SelectedSection,
                                    RelativeSource={RelativeSource AncestorType=Grid}}"
                                    Value="Exhibits">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding DataContext.SelectedSection,
                                    RelativeSource={RelativeSource AncestorType=Grid}}"
                                    Value="All">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenExhibitCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource CardButtonStyle}">

                                <Border Style="{StaticResource CardBorderStyle}"
                                        Width="180" Height="200" Margin="8">

                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                                    </Border.Effect>

                                    <StackPanel>
                                        <Border Height="120" Background="#EEE" CornerRadius="8"
                                                Margin="10,10,10,5" ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailImage}" Stretch="Uniform"/>
                                        </Border>

                                        <TextBlock Text="{Binding Name}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontSize="12"
                                                   Margin="5"
                                                   MaxHeight="40"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- СТАТЬИ -->
                <ItemsControl ItemsSource="{Binding Articles}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.SelectedSection,
                                             RelativeSource={RelativeSource AncestorType=Grid}}"
                                             Value="Articles">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.SelectedSection,
                                     RelativeSource={RelativeSource AncestorType=Grid}}"
                                     Value="All">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenArticleCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource CardButtonStyle}">

                                <Border Style="{StaticResource CardBorderStyle}"
                                        Width="160" Height="110" Margin="8" Padding="10">

                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
                                    </Border.Effect>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileType}"
                                                   FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,5,0,6"
                                                   Foreground="#4A90E2"/>

                                        <TextBlock Text="{Binding Title}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#374151"
                                                   MaxHeight="60"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ИЗОБРАЖЕНИЯ -->
                <ItemsControl ItemsSource="{Binding Images}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.SelectedSection,
                                             RelativeSource={RelativeSource AncestorType=Grid}}"
                                             Value="Images">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.SelectedSection,
                                     RelativeSource={RelativeSource AncestorType=Grid}}"
                                     Value="All">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenImageCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource CardButtonStyle}">

                                <Border Style="{StaticResource CardBorderStyle}"
                                        Width="180" Height="200" Margin="8">

                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                                    </Border.Effect>

                                    <StackPanel>
                                        <Border Height="120" Background="#EEE" CornerRadius="8"
                                                Margin="10,10,10,5" ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailImage}" Stretch="Uniform"/>
                                        </Border>

                                        <TextBlock Text="{Binding Title}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontSize="12"
                                                   Margin="5"
                                                   MaxHeight="40"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ВИДЕО -->
                <ItemsControl ItemsSource="{Binding Videos}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.SelectedSection,
                                             RelativeSource={RelativeSource AncestorType=Grid}}"
                                             Value="Videos">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.SelectedSection,
                                     RelativeSource={RelativeSource AncestorType=Grid}}"
                                     Value="All">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenVideoCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource CardButtonStyle}">

                                <Border Style="{StaticResource CardBorderStyle}"
                                        Width="220" Height="200" Margin="8">

                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                                    </Border.Effect>

                                    <StackPanel>
                                        <Border Height="120" Background="Black" CornerRadius="8"
                                                Margin="10,10,10,5" ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailImage}" Stretch="UniformToFill"/>
                                        </Border>

                                        <TextBlock Text="{Binding Title}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   FontSize="12"
                                                   Margin="5"
                                                   MaxHeight="40"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>