<UserControl x:Class="MuseumClient.Views.Details.IllustrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MuseumClient.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХ -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="16"
                Visibility="{Binding IsFullscreen,
                            Converter={StaticResource BoolToVisibilityConverter}}"
                Padding="15"
                Margin="0,20,0,10"
                BorderBrush="#E5E7EB"
                BorderThickness="2">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding DepartmentName}"
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0,4,0,0"/>

                </StackPanel>
                
                <Button Grid.Column="1"
                        Content="Скачать"
                        Command="{Binding DownloadCommand}"
                        Width="120"
                        Height="36"
                        Background="#4A90E2"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- ОСНОВНАЯ ОБЛАСТЬ -->

        <Grid Grid.Row="1"
              Margin="{Binding FullscreenMargin}">

            <Grid.RowDefinitions>

                <!-- картинка забирает всё -->
                <RowDefinition Height="*"/>

                <!-- описание снизу -->
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <!-- КАРТИНКА -->
            <Border Grid.Row="0"
        Background="White"
        CornerRadius="16"
        BorderBrush="#E5E7EB"
        BorderThickness="2"
        Padding="10"
        Margin="0,0,0,10">

                <Grid>
                    <Image Source="{Binding Image}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                    <!-- КНОПКА ПОЛНОЭКРАННОГО РЕЖИМА -->

                    <Button Width="40"
                            Height="40"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,10,10,0"
                            Command="{Binding FullscreenCommand}"
                            Background="#CC111111"
                            BorderThickness="0"
                            Cursor="Hand">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,0,2"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                        <TextBlock Text="⛶"
                                   Foreground="White"
                                   FontSize="25"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ОПИСАНИЕ -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    Visibility="{Binding IsFullscreen,
                                Converter={StaticResource BoolToVisibilityConverter}}"
                    BorderBrush="#E5E7EB"
                    BorderThickness="2"
                    Padding="15">

                <StackPanel>
                    <TextBlock Text="Описание"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="{Binding Description}"
                               TextWrapping="Wrap"
                               FontSize="15"
                               Foreground="#374151"
                               LineHeight="24"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- LOADING -->

        <Grid Grid.RowSpan="2"
              Panel.ZIndex="999"
              Background="#66000000"
              Visibility="{Binding IsLoading,
                                   Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Width="260"
                    Height="140"
                    Background="#1F2937"
                    CornerRadius="16"
                    Opacity="0.95"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <ProgressBar Width="180"
                                 Height="8"
                                 IsIndeterminate="True"
                                 Margin="0,0,0,15"/>

                    <TextBlock Text="Загрузка иллюстрации..."
                               Foreground="White"
                               FontSize="14"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
