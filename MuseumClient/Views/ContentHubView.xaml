<UserControl x:Class="MuseumClient.Views.ContentHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MuseumClient.ViewModels"
             xmlns:views="clr-namespace:MuseumClient.Views">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:AboutMuseumViewModel}">
            <views:AboutMuseumView/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <!-- Кнопки -->
            <ColumnDefinition Width="*"/>
            <!-- Контент -->
        </Grid.ColumnDefinitions>

        <!-- Панель кнопок для вкладок -->
        <StackPanel Orientation="Vertical" Grid.Column="0" Background="LightGray">
            <Button Content="О музее" Command="{Binding ShowAboutMuseumCommand}" Margin="5"/>
            <Button Content="Отделы" Command="{Binding ShowDepartmentsCommand}" Margin="5"/>
            <Button Content="Документы" Command="{Binding ShowDocumentsCommand}" Margin="5"/>
            <Button Content="Выйти" Command="{Binding ExitCommand}" Margin="5"/>
        </StackPanel>

        <!-- Контейнер для текущей вкладки -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentTabView}"/>
    </Grid>

</UserControl>