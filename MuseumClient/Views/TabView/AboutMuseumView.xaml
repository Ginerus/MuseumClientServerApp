<UserControl x:Class="MuseumClient.Views.AboutMuseumView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <!-- общий фон -->
        <Grid Background="White">

            <StackPanel>

                <!-- ========================= -->
                <!-- TITLE -->
                <!-- ========================= -->

                <TextBlock Text="Статистика"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="20,10,20,10"
                           Foreground="#334155"/>

                <!-- ========================= -->
                <!-- STATS -->
                <!-- ========================= -->

                <UniformGrid Rows="1"
                             Columns="4"
                             Margin="15,0,15,10">

                    <!-- CARD TEMPLATE STYLE -->
                    <!-- Отделы -->
                    <Border Background="White"
                            CornerRadius="14"
                            Margin="6"
                            Padding="15"
                            BorderThickness="2"
                            BorderBrush="#DDD">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Height="4"
                                    Background="#4A90E2"
                                    CornerRadius="10"/>

                            <TextBlock Text="🏢"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock Text="{Binding DepartmentCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Отделов"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Статьи -->
                    <Border Background="White"
                            CornerRadius="14"
                            Margin="6"
                            Padding="15"
                            BorderThickness="2"
                            BorderBrush="#DDD">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Height="4"
                                    Background="#22C55E"
                                    CornerRadius="10"/>

                            <TextBlock Text="📄"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock Text="{Binding DocumentCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Статей"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Экспонаты -->
                    <Border Background="White"
                            CornerRadius="14"
                            Margin="6"
                            Padding="15"
                            BorderThickness="2"
                            BorderBrush="#DDD">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Height="4"
                                    Background="#F59E0B"
                                    CornerRadius="10"/>

                            <TextBlock Text="🏺"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock Text="{Binding ExhibitCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Экспонатов"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Медиа -->
                    <Border Background="White"
                            CornerRadius="14"
                            Margin="6"
                            Padding="15"
                            BorderThickness="2"
                            BorderBrush="#DDD">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Height="4"
                                    Background="#A855F7"
                                    CornerRadius="10"/>

                            <TextBlock Text="🖼"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock Text="{Binding MediaFileCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Медиафайлов"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- ========================= -->
                <!-- INFO SECTION TITLE -->
                <!-- ========================= -->

                <TextBlock Text="О музее"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="20,15,20,10"
                           Foreground="#334155"/>

                <!-- ========================= -->
                <!-- TEXT CARD -->
                <!-- ========================= -->

                <Border Margin="20,0,20,30"
                        Padding="25"
                        Background="White"
                        CornerRadius="16"
                        BorderThickness="2"
                        BorderBrush="#DDD">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                          ShadowDepth="2"
                                          Opacity="0.08"/>
                    </Border.Effect>

                    <TextBlock TextWrapping="Wrap"
                               FontSize="14"
                               LineHeight="26"
                               Foreground="#4B5563"
                               TextAlignment="Justify">

                        В 2023 году Министерством финансов Республики Крым был реализован конкурс-проект «Школьное инициативное бюджетирование».

                        Наша школа стала одной из школ республики, которые приняли участие в проекте.

                        Учащиеся представили проект краеведческого музея «Память времён» и стали победителями конкурса.

                        В рамках реализации проекта в школе готовится к открытию краеведческий музей. Установлено приобретённое оборудование, оформлена экспозиция истории школы, история села, а также раздел «Наши соотечественники — герои войны».

                        Продолжается работа по оформлению экспозиций, посвящённых трудовым династиям села и другим важным страницам его истории.

                        Планируемая дата торжественного открытия музея — май 2024 года.

                        Музей «Память времён» направлен на сохранение и популяризацию исторического наследия наших односельчан, чьи достижения внесли значительный вклад в развитие школы и села.
                        
                        Целевая аудитория проекта: обучающиеся 1–11 классов, классные руководители, руководитель музея, родители и жители села.
                        
                        На сегодняшний день учителя и школьники активно используют музей для проведения мероприятий, уроков мужества, круглых столов и других образовательных событий.
                    </TextBlock>

                </Border>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</UserControl>