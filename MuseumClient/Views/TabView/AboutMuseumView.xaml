<UserControl x:Class="MuseumClient.Views.AboutMuseumView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <!-- общий фон -->
        <Grid Background="White">

            <StackPanel>

                <!-- ========================= -->
                <!-- TITLE -->
                <!-- ========================= -->

                <TextBlock Text="Статистика"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="20,10,20,10"
                           Foreground="#334155"/>

                <!-- ========================= -->
                <!-- STATS -->
                <!-- ========================= -->

                <UniformGrid Rows="1"
                             Columns="4"
                             Margin="15,0,15,10">

                    <!-- CARD TEMPLATE STYLE -->
                    <!-- Отделы -->
                    <Border Background="White"
                            CornerRadius="14"
                            Margin="6"
                            Padding="15"
                            BorderThickness="2"
                            BorderBrush="#DDD">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Height="4"
                                    Background="#4A90E2"
                                    CornerRadius="10"/>

                            <TextBlock Text="🏢"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock Text="{Binding DepartmentCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Отделов"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Статьи -->
                    <Border Background="White"
                            CornerRadius="14"
                            Margin="6"
                            Padding="15"
                            BorderThickness="2"
                            BorderBrush="#DDD">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Height="4"
                                    Background="#22C55E"
                                    CornerRadius="10"/>

                            <TextBlock Text="📄"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock Text="{Binding DocumentCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Статей"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Экспонаты -->
                    <Border Background="White"
                            CornerRadius="14"
                            Margin="6"
                            Padding="15"
                            BorderThickness="2"
                            BorderBrush="#DDD">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Height="4"
                                    Background="#F59E0B"
                                    CornerRadius="10"/>

                            <TextBlock Text="🏺"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock Text="{Binding ExhibitCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Экспонатов"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Медиа -->
                    <Border Background="White"
                            CornerRadius="14"
                            Margin="6"
                            Padding="15"
                            BorderThickness="2"
                            BorderBrush="#DDD">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="2"
                                              Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Height="4"
                                    Background="#A855F7"
                                    CornerRadius="10"/>

                            <TextBlock Text="🖼"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>

                            <TextBlock Text="{Binding MediaFileCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Медиафайлов"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- ========================= -->
                <!-- INFO SECTION TITLE -->
                <!-- ========================= -->

                <TextBlock Text="О музее"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="20,15,20,10"
                           Foreground="#334155"/>

                <!-- ========================= -->
                <!-- TEXT CARD -->
                <!-- ========================= -->

                <Border Margin="20,0,20,30"
        Padding="5"
        CornerRadius="16">

                    <Border.Style>
                        <Style TargetType="Border">

                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderBrush" Value="#DDD"/>
                            <Setter Property="BorderThickness" Value="2"/>

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsEditing}"
                             Value="True">

                                    <Setter Property="Background"
                            Value="#F8FBFF"/>

                                    <Setter Property="BorderBrush"
                            Value="#4A90E2"/>

                                    <Setter Property="BorderThickness"
                            Value="2"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>
                    </Border.Style>

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                          ShadowDepth="2"
                          Opacity="0.08"/>
                    </Border.Effect>

                    <!-- ========================= -->
                    <!-- INFO SECTION TITLE -->
                    <!-- ========================= -->

                    <Grid>
                        <Button Content="✏"
                                Width="26"
                                Height="26"
                                FontSize="14"
                                FontWeight="Bold"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="Black"
                                Focusable="False"
                                IsTabStop="False"
                                Panel.ZIndex="10"
                                Command="{Binding EditDescriptionCommand}"
                                Visibility="{Binding IsEditing,
                                                     Converter={StaticResource 
                                                     InverseBoolToVisibilityConverter}}">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="Root"
                                            Background="Transparent"
                                            CornerRadius="6">

                                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root"
                                                    Property="Background"
                                                    Value="#224A90E2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root"
                                                    Property="Background"
                                                    Value="#444A90E2"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                        
                        <Button Content="✔️"
                                Width="26"
                                Height="26"
                                FontSize="16"
                                FontWeight="Bold"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-2,30,0"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="Green"
                                Focusable="False"
                                IsTabStop="False"
                                Panel.ZIndex="10"
                                Command="{Binding SaveDescriptionCommand}"
                                Visibility="{Binding IsEditing,
                                                     Converter={StaticResource 
                                                     BoolToVisibilityConverter}}">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="Root"
                                            Background="Transparent"
                                            CornerRadius="6">

                                        <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root"
                                                    Property="Background"
                                                    Value="#224A90E2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root"
                                                    Property="Background"
                                                    Value="#444A90E2"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                        
                        <Button Content="❌"
                                Width="26"
                                Height="26"
                                FontSize="14"
                                FontWeight="Bold"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="Red"
                                Focusable="False"
                                IsTabStop="False"
                                Panel.ZIndex="10"
                                Command="{Binding CancelDescriptionCommand}"
                                Visibility="{Binding IsEditing,
                                                     Converter={StaticResource 
                                                     BoolToVisibilityConverter}}">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="Root"
                                            Background="Transparent"
                                            CornerRadius="6">

                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root"
                                                    Property="Background"
                                                    Value="#224A90E2"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root"
                                                    Property="Background"
                                                    Value="#444A90E2"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                        <TextBlock Text="{Binding MuseumDescription}"
                                    Margin="20"
                                    TextWrapping="Wrap"
                                    FontSize="14"
                                    LineHeight="26"
                                    Foreground="#4B5563"
                                    TextAlignment="Justify"
                                    Visibility="{Binding IsEditing,
                                                         Converter={StaticResource 
                                                         InverseBoolToVisibilityConverter}}"/>

                        <RichTextBox Margin="15, 20, 15, 20"
                                     FontSize="14"
                                     Foreground="#4B5563"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     VerticalScrollBarVisibility="Auto"
                                     Visibility="{Binding IsEditing,
                                     Converter={StaticResource BoolToVisibilityConverter}}">

                            <FlowDocument>
                                <Paragraph LineHeight="26"
                                           TextAlignment="Justify">
                                    <Run Text="{Binding MuseumDescription}"/>
                                </Paragraph>
                            </FlowDocument>

                        </RichTextBox>

                    </Grid>
                </Border>
            </StackPanel>

        </Grid>

    </ScrollViewer>

</UserControl>