<UserControl x:Class="MuseumClient.Views.AboutMuseumView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Background="White">

            <StackPanel>

                <!-- Статистика -->

                <UniformGrid Rows="1"
                             Columns="4"
                             Margin="15,0,15,10">

                    <!-- Отделы -->

                    <Border Margin="5"
                            Padding="15"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="2">

                        <StackPanel>
                            <TextBlock Text="🏢"
                                       FontSize="24"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="{Binding DepartmentCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Отделов"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Статьи -->

                    <Border Margin="5"
                            Padding="15"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="2">

                        <StackPanel>
                            <TextBlock Text="📄"
                                       FontSize="24"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="{Binding DocumentCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Статей"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Экспонаты -->

                    <Border Margin="5"
                            Padding="15"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="2">

                        <StackPanel>
                            <TextBlock Text="🏺"
                                       FontSize="24"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="{Binding ExhibitCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Экспонатов"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <!-- Медиа -->

                    <Border Margin="5"
                            Padding="15"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="2">

                        <StackPanel>
                            <TextBlock Text="🖼"
                                       FontSize="24"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="{Binding MediaFileCount}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Медиафайлов"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- История музея -->

                <Border Margin="20"
                        Padding="25"
                        Background="White"
                        CornerRadius="16"
                        BorderBrush="#E5E7EB"
                        BorderThickness="2">

                    <StackPanel>

                        <TextBlock Text="О музее"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <TextBlock TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="#374151"
                                   LineHeight="24">

                            В 2023 году Министерством финансов Республики Крым был реализован конкурс-проект «Школьное инициативное бюджетирование».

                            Наша школа стала одной из школ республики, которые приняли участие в проекте.

                            Учащиеся представили проект краеведческого музея «Память времён» и стали победителями конкурса.

                            В рамках реализации проекта в школе готовится к открытию краеведческий музей. Установлено приобретённое оборудование, оформлена экспозиция истории школы, история села, а также раздел «Наши соотечественники — герои войны».

                            Продолжается работа по оформлению экспозиций, посвящённых трудовым династиям села и другим важным страницам его истории.

                            Планируемая дата торжественного открытия музея — май 2024 года.

                            Музей «Память времён» направлен на сохранение и популяризацию исторического наследия наших односельчан, чьи достижения внесли значительный вклад в развитие школы и села.

                            Целевая аудитория проекта: обучающиеся 1–11 классов, классные руководители, руководитель музея, родители и жители села.

                            На сегодняшний день учителя и школьники активно используют музей для проведения мероприятий, уроков мужества, круглых столов и других образовательных событий.

                        </TextBlock>

                    </StackPanel>

                </Border>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</UserControl>