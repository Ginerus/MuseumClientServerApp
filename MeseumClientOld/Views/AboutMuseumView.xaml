<UserControl x:Class="MeseumClient.Views.AboutMuseumView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MeseumClient.Views"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="20">
            <!-- Заголовок -->
            <TextBlock Text="О музее" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#1E90FF" 
                       Margin="0,0,0,20"/>

            <UniformGrid Columns="4" Margin="0,0,0,20">

                <!-- Статьи -->
                <Border Background="#F0F8FF" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Статьи" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="{Binding ArticlesCount}" FontSize="24" Foreground="#1E90FF"/>
                    </StackPanel>
                </Border>

                <!-- Отделы -->
                <Border Background="#F5FFF0" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Отделы" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="{Binding DepartmentsCount}" FontSize="24" Foreground="#2E8B57"/>
                    </StackPanel>
                </Border>

                <!-- Экспонаты -->
                <Border Background="#FFF8F0" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Экспонаты" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="{Binding ExhibitsCount}" FontSize="24" Foreground="#FF8C00"/>
                    </StackPanel>
                </Border>

                <!-- Медиа -->
                <Border Background="#FFF0F5" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Медиа" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="{Binding MediaCount}" FontSize="24" Foreground="#C71585"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Основной текст -->
            <TextBlock TextWrapping="Wrap" FontSize="16" Foreground="#000000">
                Добро пожаловать в наш музей! 
                Здесь вы можете познакомиться с уникальными экспонатами, узнать историю времён и окунуться в атмосферу прошлого. 
                Музей предлагает экскурсии, выставки, образовательные программы и мультимедийные материалы для всех возрастов.
            </TextBlock>

            <!-- Дополнительная информация -->
            <TextBlock TextWrapping="Wrap" FontSize="16" Foreground="#333333" Margin="0,10,0,0">
                Наши отделы включают археологию, искусство, историю науки и культуры. 
                Мы рады гостям и стремимся сделать каждый визит интересным и познавательным.
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>