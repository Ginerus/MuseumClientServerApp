<UserControl x:Class="MeseumClient.Views.LoginView" 
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
xmlns:local="clr-namespace:MeseumClient.Helpers" 
xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
x:Name="RootControl">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:WindowRatioToColumnWidthConverter x:Key="WindowRatioToColumnWidthConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <local:BoolToToolTipConverter x:Key="BoolToToolTipConverter"/>

        <!-- Стиль кнопки -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#357ABD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2C5F9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="#F5F6FA">
        <Grid.ColumnDefinitions>
            <!-- Левая колонка: растёт, но видна только если достаточно места -->
            <ColumnDefinition Width="*" MinWidth="0" />
            <!-- Правая колонка: тоже растёт -->
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>
        <!-- Левая панель -->
        <Border Grid.Column="0" Background="#4A90E2" MinWidth="200" Visibility="{Binding ActualWidth, ElementName=RootControl, Converter={StaticResource WindowRatioToColumnWidthConverter}}">
            <!-- Viewbox масштабирует содержимое -->
            <Viewbox Stretch="Uniform" StretchDirection="Both" Margin="40" MaxWidth="500">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Круглый логотип -->
                    <Ellipse Width="150" Height="150" Margin="0,0,0,20">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="pack://Application:,,,/Resources/logo.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Добро пожаловать" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="в музей &quot;Память времён&quot;" Foreground="White" FontSize="14" Opacity="0.9" Margin="0,5,0,0"/>
                        <TextBlock Text="Система управления экспонатами" Foreground="White" FontSize="12" Opacity="0.7" Margin="0,10,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Viewbox>
        </Border>
        <!-- Правая панель -->
        <Border Grid.Column="1" Background="White" Padding="30" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>
            <Viewbox Stretch="Uniform" StretchDirection="Both" Margin="40" MaxWidth="200" MinHeight="170">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <TextBlock Text="Войти в музей" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,25" HorizontalAlignment="Center"/>
                        <TextBlock Text="Пользователь" Opacity="0.7"/>
                        <ComboBox Height="35" Margin="0,5,0,0" ItemsSource="{Binding UserTypes}" SelectedItem="{Binding SelectedUserType, Mode=TwoWay}" DisplayMemberPath="Display"/>

                        <StackPanel Margin="0,15,0,0" Visibility="{Binding IsPasswordFieldVisible, Converter={StaticResource BoolToVisibility}}">
                            <!-- Надпись всегда видна -->
                            <TextBlock Text="Пароль" Opacity="0.7"/>

                            <!-- Контейнер для поля пароля -->
                            <Grid>
                                <!-- PasswordBox для скрытого пароля -->
                                <!-- PasswordBox для скрытого пароля -->
                                <PasswordBox x:Name="PasswordBoxField"
                                             Height="35" 
                                             Padding="5,0,35,0"
                                             local:PasswordHelper.BindPassword="True"
                                             local:PasswordHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVisibility}}"/>

                                <!-- TextBox для открытого пароля -->
                                <TextBox x:Name="VisiblePasswordBox" 
                                         Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="35" 
                                         Padding="5,0,35,0"
                                         Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVisibility}}"/>

                                <!-- Кнопка глазика -->
                                <Button Width="30" 
                                        Height="30"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        Command="{Binding TogglePasswordVisibilityCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTip="{Binding IsPasswordVisible, Converter={local:BoolToToolTipConverter}, ConverterParameter='Скрыть|Показать'}">

                                    <!-- SVG иконка глаза -->
                                    <svg:SvgViewbox Width="20" Height="20">
                                        <svg:SvgViewbox.Style>
                                            <Style TargetType="svg:SvgViewbox">
                                                <Setter Property="Source" Value="pack://Application:,,,/Resources/EyePassword/EyePasswordHide.svg"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                        <Setter Property="Source" Value="pack://application:,,,/Resources/EyePassword/EyePasswordShow.svg"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </svg:SvgViewbox.Style>
                                    </svg:SvgViewbox>
                                </Button>
                            </Grid>
                        </StackPanel>
                        <Button Content="Войти" Margin="0,25,0,0" Command="{Binding LoginCommand}"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#E74C3C" Margin="0,15,0,0" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Viewbox>
        </Border>
    </Grid>
</UserControl>